# swf-alarms engine config — copy to config.toml.
#
# Alarm *configurations* (thresholds, recipients, severities, enabled flags)
# live in the DB as kind='alarm' entries in the swf-alarms context. Edit
# them in the dashboard UI, not here. This file only has settings the
# engine itself needs to start up.

[engine]
# Loopback through swf-remote's Apache. swf-remote owns the SSH tunnel
# to pandaserver02; this engine never talks to BNL directly.
swf_remote_base_url = "https://epic-devcloud.org/prod"
request_timeout = 20
log_path = "/var/log/swf-alarms/run.log"

# Postgres — alarm state goes in swf-remote's own DB. By default the
# engine reads SWF_REMOTE_DB_* from swf-remote's .env so there is one
# source of truth.
[db]
# env_path = "/var/www/swf-remote/src/.env"
# Or explicit DSN override:
# dsn = "postgresql://swf_remote:PASSWORD@localhost:5432/swf_remote"

[email]
provider = "ses"
region = "us-east-1"
from = "wenaus@gmail.com"
